# Required
DATABASE_URL=postgres://user:password@localhost:5432/db
VOYAGE_API_KEY=your-voyage-api-key
API_TOKEN=change-me

# Optional defaults
EMBED_MODEL=voyage-4
QUERY_MODEL=voyage-4-lite
RERANK_MODEL=rerank-2.5-lite
EMBED_DIM=1024
CANDIDATE_K=50
RESULT_K=10
MAX_FACTS_PER_REQUEST=100
MAX_FACT_CHARS=2000
CORS_ORIGINS=
